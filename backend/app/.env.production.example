# Production Cloud Run env (Phase 5).
# DO NOT commit real values. Load via `gcloud run deploy --update-env-vars`
# or (preferred) Secret Manager + --set-secrets.
#
# ─── Supabase (server-side, SERVICE ROLE — bypasses RLS) ─────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<sb_secret_... or legacy service_role JWT>

# ─── Gemini ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=<AIza...>
GOAT_AI_ENABLED=1
GOAT_AI_FAKE_MODE=0
GOAT_AI_MODEL=gemini-2.5-flash-lite

# ─── Edge Function ↔ Backend shared secret ──────────────────────────────
# Must match the same secret stored on the Supabase Edge Function.
# Generate with: openssl rand -hex 48
GOAT_BACKEND_SHARED_SECRET=<long-random-hex>
# Fail-closed: refuse protected routes if the secret is missing.
GOAT_REQUIRE_SHARED_SECRET=1

# ─── Safety flags ────────────────────────────────────────────────────────
# Keep the dev endpoint disabled in production.
GOAT_ALLOW_DEV_ENDPOINTS=0
# Never set GOAT_TEST_USER_ID on Cloud Run.

# ─── Runtime ─────────────────────────────────────────────────────────────
# Cloud Run passes PORT automatically; no need to set here.
