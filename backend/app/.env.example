# Copy to .env for local runs. Never commit real values.
# ─── Supabase (local Supabase CLI defaults) ─────────────────────────────
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=

# ─── Goat Mode dev flags ────────────────────────────────────────────────
# Enables the dev-only POST /goat-mode/run-for-user endpoint.
# MUST stay 0 (or unset) in production Cloud Run deployments. Set to 1 only
# on local workstations when exercising the dev runner by hand.
GOAT_ALLOW_DEV_ENDPOINTS=0

# Default test user UUID used by cli.py and /run-for-user when none is supplied.
# Only consulted when GOAT_ALLOW_DEV_ENDPOINTS=1. Leave empty in production.
GOAT_TEST_USER_ID=

# ─── Gemini AI layer (Phase 4) ──────────────────────────────────────────
# Secret from https://aistudio.google.com/app/apikey. Required for mode=real.
GEMINI_API_KEY=
# Master switch. 0 → fallback deterministic phrasing only. 1 → try Gemini.
GOAT_AI_ENABLED=0
# When 1, bypass real Gemini calls and use a deterministic stand-in.
# Useful for local tests without network/API quota.
GOAT_AI_FAKE_MODE=0
# Override the default model (gemini-3-flash-preview).
# GOAT_AI_MODEL=gemini-3-flash-preview

# ─── Edge Function ↔ Backend shared secret (Phase 5) ────────────────────
# Cloud Run may be allow-unauthenticated so the Supabase Edge Function can
# reach it without service-account plumbing. Every request to /goat-mode/*
# must then carry this secret in the X-Goat-Backend-Secret header. The Edge
# Function reads the same value from its Supabase function secrets, so set
# them to identical strings in both places.
# Generate with: openssl rand -hex 48
GOAT_BACKEND_SHARED_SECRET=
# When 1, fail-closed if GOAT_BACKEND_SHARED_SECRET is missing — use on
# Cloud Run to prevent accidentally shipping with enforcement disabled.
# Recommended production value: 1. Local-dev default: 0 (see docs/GOAT_MODE_
# PHASE8_RELEASE_HARDENING_CHECKLIST.md for full deployment notes).
GOAT_REQUIRE_SHARED_SECRET=0
