GEMINI_API_KEY=your-gemini-api-key

# Billy AI backend (FastAPI on Cloud Run). Used for GOAT mode and future AI routes.
# Flutter reads this via --dart-define-from-file or --dart-define=BILLY_AI_BACKEND_URL=...
BILLY_AI_BACKEND_URL=https://billy-ai-eq3uykqo2q-el.a.run.app

# Optional: Supabase CLI (Dashboard → Account → Access tokens). Never commit real values; never paste tokens in chat.
