SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
GEMINI_API_KEY=your-gemini-api-key

# Optional: Supabase CLI (Dashboard → Account → Access tokens). Never commit real values.
# Deploy scripts prefer supabase1234 when set, then SUPABASE_ACCESS_TOKEN (avoids stale PAT under the standard name).
SUPABASE_ACCESS_TOKEN=your-supabase-access-token
# supabase1234=optional-local-alias-same-as-pat
