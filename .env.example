SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
GEMINI_API_KEY=your-gemini-api-key

# Billy AI backend (FastAPI on Cloud Run). Used for GOAT mode and future AI routes.
# Flutter reads this via --dart-define-from-file or --dart-define=BILLY_AI_BACKEND_URL=...
BILLY_AI_BACKEND_URL=https://billy-ai-eq3uykqo2q-el.a.run.app

# Optional: Vercel CLI (scripts/deploy-vercel.ps1). Use the project that serves https://web-iota-lilac-34.vercel.app
# VERCEL_TOKEN=vcp_...
# VERCEL_ORG_ID=team_...
# VERCEL_PROJECT_ID=prj_...
# VERCEL_SCOPE=mannbillywes-projects

# Optional: Supabase CLI (Dashboard → Account → Access tokens). Never commit real values; never paste tokens in chat.
# After linking: npx supabase db push && npm run supabase:deploy-analytics-insights
SUPABASE_ACCESS_TOKEN=your-supabase-access-token
# GOAT_GEMINI_API_KEY=optional-second-key-for-goat-analytics-edge
# supabase1234=optional-local-alias-same-as-pat
